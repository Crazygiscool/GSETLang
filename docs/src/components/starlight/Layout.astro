---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Layout.astro';
---

<div class="ambient-background">
	<div class="glow-orb glow-orb-1"></div>
	<div class="glow-orb glow-orb-2"></div>
	<div class="glow-orb glow-orb-3"></div>
</div>

<Default {...Astro.props}>
	<slot slot="header" slot="header" />
</Default>

<style>
	.ambient-background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: -1;
		overflow: hidden;
	}
</style>
